# Vault contents (personal source files, never pushed to GitHub)
vault/*
!vault/.gitkeep

# Vault FTS5 database (derived artifact, rebuilt by setup.sh)
*.db
*.db-wal
*.db-shm

# Wiki — everything inside wiki/ is managed by its own inner git repo.
# The outer repo never ships wiki/ content; setup.sh creates it from template/.
wiki/

# The working-dir CLAUDE.md is generated by setup.sh per-instance
# (anchored to root so template/CLAUDE.md remains tracked)
/CLAUDE.md

# OS junk
.DS_Store
Thumbs.db
*~
